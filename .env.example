# AWS Bedrock credentials
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=        # Only needed for temporary/assumed-role credentials
# AWS_PROFILE=              # Alternative: use named profile from ~/.aws/credentials

# Bedrock model ID — check available models in your AWS account/region
# Common options:
#   us.anthropic.claude-sonnet-4-5-20250514-v1:0   (Claude Sonnet 4, cross-region)
#   us.anthropic.claude-3-5-sonnet-20241022-v2:0   (Claude 3.5 Sonnet, cross-region)
#   anthropic.claude-3-5-sonnet-20241022-v2:0       (single-region)
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250514-v1:0

# GitHub
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Webhook server
WEBHOOK_SECRET=
PORT=3000

# k6 base URL
BASE_URL=http://localhost:3000
